{
  "_comment": "P1 各文件类型的格式说明书（数据驱动）。代码只读它，不写死。",

  "files": {
    "_comment": "路径片段 → 格式名。按文件夹/名字判类型最可靠。",
    "/TALK/": "talk",
    "/ADV/E0.BIN": "efile",
    "/ADV/E1.BIN": "efile",
    "/ADV/E2.BIN": "efile",
    "/ADV/E3.BIN": "efile",
    "/SLPS_005.00": "slps"
  },

  "skip_globs": ["STR*", "*.VB", "*.STR", "*.BGD"],

  "ctrl": {
    "_comment": "控制码表：每种文件一张。键=FF后那个字节(16进制字符串)，值=[名字, 整条占几字节]。名字叫 nl 的会被渲染成真换行。",

    "talk": {
      "0xFF": ["pad", 2],
      "0xF6": ["nl", 2],
      "0xF5": ["end", 2],
      "0xFC": ["c_fc", 2],
      "0xFD": ["c_fd", 3],
      "0xEF": ["c_ef", 2],
      "0xF1": ["c_f1", 2],
      "0x01": ["c_01", 2]
    },

    "efile": {
      "0xFF": ["pad", 2],
      "0x01": ["close", 2],
      "0x02": ["wait", 2],
      "0x03": ["nl", 2],
      "0x04": ["clear", 2],
      "0x05": ["pause", 4],
      "0x06": ["color", 3],
      "0x07": ["name", 3],
      "0x08": ["name_08", 3],
      "0x0E": ["choice", 3],
      "0x0F": ["var_0f", 3],
      "0x11": ["var_11", 2],
      "0x12": ["var_12", 2]
    },

    "dfile": {
      "0x01": ["close", 2],
      "0x02": ["wait", 2],
      "0x03": ["nl", 2],
      "0x04": ["clear", 2],
      "0x05": ["pause", 4],
      "0x06": ["color", 3],
      "0x07": ["first_name", 3],
      "0x08": ["nickname", 3],
      "0x0E": ["choice", 3],
      "0x0F": ["last_name", 3],
      "0x10": ["full_name", 3],
      "0x11": ["var_11", 2],
      "0x12": ["var_12", 2]
    },

    "slps": {
      "0x03": ["nl", 2]
    }
  }
}
